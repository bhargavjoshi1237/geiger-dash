# Existing Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# Prisma/Postgres
# Use the transaction-mode pooler at runtime and the session-mode pooler for migrations.
DATABASE_URL=
DIRECT_URL=

# Email subsystem (geiger-dash hosts the suite's transactional email)
# RESEND_API_KEY powers delivery; EMAIL_FROM is the default From address.
RESEND_API_KEY=
EMAIL_FROM="Geiger <noreply@geiger.studio>"
# Public base URL used for links/branding inside emails.
NEXT_PUBLIC_APP_URL=https://geiger.studio

# Automatic blog pipeline
BLOG_AUTOMATION_ENABLED=true
BLOG_AUTOMATION_AUTO_PUBLISH=true
BLOG_AUTOMATION_DAILY_LIMIT=12
BLOG_AUTOMATION_QUALITY_THRESHOLD=82
BLOG_AUTOMATION_RESEARCH_RESULTS=8
BLOG_AUTOMATION_AUTHOR_NAME=Geiger Research Team
BLOG_AUTOMATION_DEFAULT_CATEGORY=Tutorials
BLOG_AUTOMATION_SEED_TOPICS=new AI tools, AI use cases, AI best practices, new technologies, industry trends, how-to guides, case studies, expert interviews


BLOG_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
BLOG_LLM_API_KEY=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
BLOG_LLM_MODELS=minimaxai/minimax-m3,moonshotai/kimi-k2.6,deepseek-ai/deepseek-v4-pro,z-ai/glm-5.1
BLOG_LLM_INPUT_PRICE_PER_MILLION=0
BLOG_LLM_OUTPUT_PRICE_PER_MILLION=0

# One OpenAI-compatible endpoint with one or more comma-separated models

BLOG_SEARCH_API_URL=https://api.tavily.com/search
BLOG_SEARCH_API_KEY=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

# Optional advanced multi-provider setup. When set, this overrides the fields above.
# Keep this JSON on one line. apiKey may be omitted to use BLOG_LLM_API_KEY.
# BLOG_LLM_PROFILES=[{"id":"fast","roles":["strategist","researcher"],"baseUrl":"https://api.example.com/v1","apiKey":"","model":"model-a","inputPricePerMillion":0,"outputPricePerMillion":0},{"id":"writer","roles":["critic","writer","reviewer"],"baseUrl":"https://api.example.com/v1","apiKey":"","model":"model-b","inputPricePerMillion":0,"outputPricePerMillion":0}]

# Optional Tavily-compatible web research endpoint. Without this, the pipeline
# still runs but explicitly avoids current facts and statistics.
